#!/usr/bin/env zsh
set -euo pipefail

SCRIPT_DIR="${0:A:h}"
export SWIFT_MODULE_CACHE_PATH="${TMPDIR:-/tmp}/brightness-keeper-swift-cache"
export CLANG_MODULE_CACHE_PATH="$SWIFT_MODULE_CACHE_PATH"
mkdir -p "$SWIFT_MODULE_CACHE_PATH"

exec /usr/bin/swift -module-cache-path "$SWIFT_MODULE_CACHE_PATH" "$SCRIPT_DIR/brightness-keeper.swift" "$@"
